{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "save-memory-v2.schema.json",
  "title": "save_memory v2",
  "type": "object",
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "string",
      "enum": ["chatgpt", "claude", "grok", "cursor", "manual"]
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": ["decision", "fact", "preference", "todo", "summary"]
      }
    },
    "topics": {
      "type": "array",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 64
      }
    },
    "entities": {
      "type": "array",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "projects": {
      "type": "array",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "tags": {
      "type": "array",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 80
      }
    },
    "raw_refs": {
      "type": "array",
      "default": [],
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 120
      }
    },
    "relations": {
      "type": "array",
      "default": [],
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": ["supports", "contradicts", "follows", "supersedes", "depends_on", "mentions"]
          },
          "target_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": ["type", "target_id"],
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "default": 0.8
    },
    "status": {
      "type": "string",
      "enum": ["active", "superseded", "archived"],
      "default": "active"
    },
    "occurred_at": {
      "type": "string",
      "format": "date-time"
    },
    "due_at": {
      "type": "string",
      "format": "date-time"
    },
    "language": {
      "type": "string",
      "default": "ko"
    },
    "notes": {
      "type": "string",
      "maxLength": 2000
    }
  },
  "required": [
    "schema_version",
    "title",
    "content",
    "source",
    "roles"
  ],
  "additionalProperties": false
}
