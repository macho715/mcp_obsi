# local-only mode
MYAGENT_PROXY_HOST=127.0.0.1
MYAGENT_PROXY_PORT=3010
MYAGENT_PROXY_OPS_LOGS=1
MYAGENT_PROXY_ALLOW_SANITIZED_TO_COPILOT=0

# default origins are always included:
# - http://127.0.0.1:4173
# - http://127.0.0.1:18789
# add extra origins if needed
MYAGENT_PROXY_CORS_ORIGINS=

# local mode usually keeps auth token empty
MYAGENT_PROXY_AUTH_TOKEN=
