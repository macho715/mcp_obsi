{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "memory-item-v2.schema.json",
  "title": "MemoryNoteV2",
  "type": "object",
  "properties": {
    "schema_type": {
      "type": "string",
      "const": "memory_item"
    },
    "schema_version": {
      "type": "string",
      "const": "2.0"
    },
    "note_kind": {
      "type": "string",
      "const": "memory"
    },
    "memory_id": {
      "type": "string",
      "pattern": "^MEM-\\d{8}-\\d{6}-[0-9A-F]{6}$"
    },
    "memory_type": {
      "type": "string",
      "enum": [
        "preference",
        "project_fact",
        "decision",
        "person",
        "todo",
        "conversation_summary"
      ]
    },
    "roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "decision",
          "fact",
          "preference",
          "todo",
          "summary"
        ]
      }
    },
    "source": {
      "type": "string"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "updated_at_utc": {
      "type": "string",
      "format": "date-time"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 200
    },
    "content": {
      "type": "string",
      "minLength": 1
    },
    "project": {
      "type": [
        "string",
        "null"
      ]
    },
    "topics": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "raw_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "target_id": {
            "type": "string",
            "minLength": 1
          }
        },
        "required": [
          "type",
          "target_id"
        ],
        "additionalProperties": false
      }
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "superseded",
        "archived"
      ]
    },
    "sensitivity": {
      "type": "string"
    },
    "language": {
      "type": "string"
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "mcp_sig": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "required": [
    "schema_type",
    "schema_version",
    "note_kind",
    "memory_id",
    "roles",
    "source",
    "created_by",
    "created_at_utc",
    "updated_at_utc",
    "title",
    "content"
  ],
  "additionalProperties": false
}
