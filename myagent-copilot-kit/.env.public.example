# public mode (required for Vercel/remote dashboard)
MYAGENT_PROXY_HOST=0.0.0.0
MYAGENT_PROXY_PORT=3010
MYAGENT_PROXY_OPS_LOGS=1
MYAGENT_PROXY_ALLOW_SANITIZED_TO_COPILOT=0

# required: your dashboard origins
MYAGENT_PROXY_CORS_ORIGINS=https://your-dashboard.vercel.app

# required: shared secret for /api/ai/chat
MYAGENT_PROXY_AUTH_TOKEN=replace-with-strong-secret
